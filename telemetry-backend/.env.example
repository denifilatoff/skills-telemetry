# Site address Caddy serves and obtains a TLS certificate for.
# VPS with a public IP: use <ip-with-dashes>.sslip.io  (e.g. 203-0-113-10.sslip.io).
# Local dev: use "localhost" (Caddy issues an internal CA cert, no DNS needed).
SITE_ADDRESS=203-0-113-10.sslip.io

# TLS mode passed to Caddy's `tls` directive.
# VPS: an ACME email (e.g. admin@example.com) — Caddy obtains a Let's Encrypt cert.
# Local: "internal" — Caddy mints a self-signed cert for localhost.
CADDY_TLS=admin@example.com

# Shared write-only bearer token for telemetry ingest.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_TOKEN=change-me-long-random

# VictoriaLogs log retention.
VL_RETENTION=30d

# Host ports Caddy binds to.
# VPS: keep 80/443 (Let's Encrypt needs port 80 for the ACME challenge).
# Local: pick free ports if 80/443 are taken (e.g. 8080/8443).
HTTP_PORT=80
HTTPS_PORT=443
